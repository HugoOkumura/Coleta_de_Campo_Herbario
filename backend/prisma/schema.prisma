generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"  // veja se tem essa linha e qual caminho está configurado
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Estado {
  id_estado  String    @id @db.Char(2)
  nm_estado  String    @db.VarChar(40)
  municipios Municipio[]
}

model Municipio {
  id_municipio Int       @id       // removido @db.Numeric(2)
  nm_municipio String    @db.VarChar(40)
  id_estado    String    @db.Char(2)
  estado       Estado    @relation(fields: [id_estado], references: [id_estado])
  expedicoes   Expedicao[]
}

model TipoVegetacao {
  id_vegetacao Int        @id       // removido @db.Numeric(5)
  nm_vegetacao String     @db.VarChar(40)
  expedicoes   Expedicao[]
}

model TipoRelevo {
  id_relevo Int     @id            // removido @db.Numeric(5)
  nm_relevo String  @db.VarChar(40)
  amostras  Amostra[]
}

model TipoSolo {
  id_solo Int    @id                // removido @db.Numeric(5)
  nm_solo String @db.VarChar(40)
  amostras Amostra[]
}

model Expedicao {
  id_expedicao   Int              @id    @default(autoincrement()) // removido @db.Numeric(7)
  ds_titulo      String
  dt_expedicao   DateTime         @db.Date
  in_aberto      Boolean          @default(true)
  id_municipio   Int                        // removido @db.Numeric(7)
  id_vegetacao   Int?                       // removido @db.Numeric(5)

  municipio      Municipio        @relation(fields: [id_municipio], references: [id_municipio])
  tipoVegetacao  TipoVegetacao?   @relation(fields: [id_vegetacao], references: [id_vegetacao])
  expedicaoMidia ExpedicaoMidia[]
  amostras      Amostra[]
}

model ExpedicaoMidia {
  id_expedicaomidia Int       @id         // removido @db.Numeric(9)
  id_expedicao      Int?                      // removido @db.Numeric(9)
  tp_arquivo        String    @db.VarChar(50)
  arquivo           Bytes
  descricao         String?   @db.Text
  data_upload       DateTime  @default(now()) @db.Timestamp(6)
  expedicao         Expedicao? @relation(fields: [id_expedicao], references: [id_expedicao])
}

model DadoEcologico {
  id_dadoeco Int       @id
  ds_dadoeco String    @db.VarChar(50)
  item_dados ItemDado[]
  planta_dados PlantaDado[]   // <-- aqui
  amostra_dados AmostraDado[] // <-- e aqui
}

model ItemDado {
  id_dadoeco  Int    // removido @db.Numeric(2)
  id_itemdado Int    // removido @db.Numeric(2)
  ds_itemdado String @db.VarChar(50)

  dadoEcologico DadoEcologico @relation(fields: [id_dadoeco], references: [id_dadoeco])

  planta_dados PlantaDado[]
  amostra_dados AmostraDado[]

  @@id([id_dadoeco, id_itemdado])
}

model Planta {
  id_planta     Int          @id    // removido @db.Numeric(9)
  nm_vulgar     String       @db.VarChar(255)
  nm_cientifico String       @db.VarChar(255)
  nm_familia    String       @db.VarChar(100)
  planta_dados  PlantaDado[]
  amostras      Amostra[]
}

model PlantaDado {
  id_planta     Int
  id_dadoeco    Int
  id_itemdado   Int
  ds_obs        String?      @db.VarChar(255)

  planta       Planta      @relation(fields: [id_planta], references: [id_planta])
  item_dado    ItemDado    @relation(fields: [id_dadoeco, id_itemdado], references: [id_dadoeco, id_itemdado])

  dadoEcologico DadoEcologico @relation(fields: [id_dadoeco], references: [id_dadoeco])  // << Adicione isso

  @@id([id_planta, id_dadoeco, id_itemdado])
}

model Amostra {
  id_amostra       Int          @id      // removido @db.Numeric(9)
  id_planta        Int?                 // removido @db.Numeric(9)
  id_expedicao     Int?                 // removido @db.Numeric(7)
  id_relevo        Int?                 // removido @db.Numeric(5)
  id_solo          Int?                 // removido @db.Numeric(5)
  nm_coletor       String       @db.VarChar(160)
  nr_altitude      Decimal?     // removido @db.Numeric(6, 2)
  nr_longitude     Decimal?     // removido @db.Numeric(9, 6)
  nr_latitude      Decimal?     // removido @db.Numeric(9, 6)
  nr_altura        Decimal?     // removido @db.Numeric(5, 2)
  nr_DAP           Decimal?     // removido @db.Numeric(5, 2)
  nr_CAP           Decimal?     // removido @db.Numeric(5, 2)
  ds_exsudado      String?      @db.VarChar(100)
  ds_obscomplement String?      @db.VarChar(400)

  planta      Planta?      @relation(fields: [id_planta], references: [id_planta])
  expedicao   Expedicao?   @relation(fields: [id_expedicao], references: [id_expedicao])
  tipoRelevo  TipoRelevo?  @relation(fields: [id_relevo], references: [id_relevo])
  tipoSolo    TipoSolo?    @relation(fields: [id_solo], references: [id_solo])

  amostra_dados AmostraDado[]
  amostra_midias AmostraMidia[]
}

model AmostraDado {
  id_amostra   Int
  id_dadoeco   Int
  id_itemdado  Int
  ds_cor       String?    @db.VarChar(255)
  ds_obs       String?    @db.VarChar(255)

  amostra    Amostra    @relation(fields: [id_amostra], references: [id_amostra])
  item_dado  ItemDado   @relation(fields: [id_dadoeco, id_itemdado], references: [id_dadoeco, id_itemdado])

  dadoEcologico DadoEcologico @relation(fields: [id_dadoeco], references: [id_dadoeco])  // << E aqui

  @@id([id_amostra, id_dadoeco, id_itemdado])
}


model AmostraMidia {
  id_amostramidia Int      @id      // removido @db.Numeric(9)
  id_amostra      Int?                 // removido @db.Numeric(9)
  tp_arquivo      String   @db.VarChar(50)
  arquivo         Bytes
  descricao       String?  @db.Text
  data_upload     DateTime @default(now()) @db.Timestamp(6)

  amostra         Amostra? @relation(fields: [id_amostra], references: [id_amostra])
}
