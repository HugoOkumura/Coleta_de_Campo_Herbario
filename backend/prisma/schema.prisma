generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Estado {
  id_estado  String    @id @db.Char(2)
  nm_estado  String    @db.VarChar(40)
  municipios Municipio[]
}

model Municipio {
  id_municipio Int       @id @default(autoincrement())
  nm_municipio String    @db.VarChar(40)
  id_estado    String    @db.Char(2)
  estado       Estado    @relation(fields: [id_estado], references: [id_estado])
  expedicoes   Expedicao[]
}

model TipoVegetacao {
  id_vegetacao Int        @id @default(autoincrement())
  nm_vegetacao String     @db.VarChar(40)
  expedicoes   Expedicao[]
}

model TipoRelevo {
  id_relevo Int     @id @default(autoincrement())
  nm_relevo String  @db.VarChar(40)
  amostras  Amostra[]
}

model TipoSolo {
  id_solo Int    @id  @default(autoincrement())
  nm_solo String @db.VarChar(40)
  amostras Amostra[]
}

model Expedicao {
  id_expedicao   Int              @id    @default(autoincrement())
  ds_titulo      String
  dt_expedicao   DateTime         @db.Date
  in_aberto      Boolean          @default(true)
  id_municipio   Int
  id_vegetacao   Int?

  municipio      Municipio        @relation(fields: [id_municipio], references: [id_municipio])
  tipoVegetacao  TipoVegetacao?   @relation(fields: [id_vegetacao], references: [id_vegetacao])
  expedicaoMidia ExpedicaoMidia[]
  amostras       Amostra[]
}

model ExpedicaoMidia {
  id_expedicaomidia Int       @id @default(autoincrement())
  id_expedicao      Int?
  tp_arquivo        String    @db.VarChar(50)
  arquivo           Bytes
  descricao         String?   @db.Text
  data_upload       DateTime  @default(now()) @db.Timestamp(6)
  expedicao         Expedicao? @relation(fields: [id_expedicao], references: [id_expedicao])
}

model DadoEcologico {
  id_dadoeco Int       @id 
  ds_dadoeco String    @db.VarChar(50)
  item_dados ItemDado[]
  planta_dados PlantaDado[]
  amostra_dados AmostraDado[]
}

model ItemDado {
  id_dadoeco  Int
  id_itemdado Int
  ds_itemdado String @db.VarChar(50)

  dadoEcologico DadoEcologico @relation(fields: [id_dadoeco], references: [id_dadoeco])

  planta_dados  PlantaDado[]
  amostra_dados AmostraDado[]

  @@id([id_dadoeco, id_itemdado])
}

model Planta {
  id_planta     Int          @id @default(autoincrement())
  nm_vulgar     String       @db.VarChar(255)
  nm_cientifico String       @db.VarChar(255)
  nm_familia    String       @db.VarChar(100)
  planta_dados  PlantaDado[]
  amostras      Amostra[]
}

model PlantaDado {
  id_planta     Int
  id_dadoeco    Int
  id_itemdado   Int
  ds_obs        String?      @db.VarChar(255)

  planta         Planta        @relation(fields: [id_planta], references: [id_planta])
  item_dado      ItemDado      @relation(fields: [id_dadoeco, id_itemdado], references: [id_dadoeco, id_itemdado])
  dadoEcologico  DadoEcologico @relation(fields: [id_dadoeco], references: [id_dadoeco])

  @@id([id_planta, id_dadoeco, id_itemdado])
}

model Amostra {
  id_amostra       Int          @id  @default(autoincrement())
  id_planta        Int?
  id_expedicao     Int?
  id_relevo        Int?
  id_solo          Int?
  nm_coletor       String       @db.VarChar(160)
  nr_altitude      Decimal?
  nr_longitude     Decimal?
  nr_latitude      Decimal?
  nr_altura        Decimal?
  nr_DAP           Decimal?
  nr_CAP           Decimal?
  ds_exsudado      String?      @db.VarChar(100)
  ds_obscomplement String?      @db.VarChar(400)

  planta          Planta?       @relation(fields: [id_planta], references: [id_planta])
  expedicao       Expedicao?    @relation(fields: [id_expedicao], references: [id_expedicao])
  tipoRelevo      TipoRelevo?   @relation(fields: [id_relevo], references: [id_relevo])
  tipoSolo        TipoSolo?     @relation(fields: [id_solo], references: [id_solo])
  amostra_dados   AmostraDado[]
  amostra_midias  AmostraMidia[]
}

model AmostraDado {
  id_amostra   Int
  id_dadoeco   Int
  id_itemdado  Int
  ds_cor       String?    @db.VarChar(255)
  ds_obs       String?    @db.VarChar(255)

  amostra        Amostra       @relation(fields: [id_amostra], references: [id_amostra])
  item_dado      ItemDado      @relation(fields: [id_dadoeco, id_itemdado], references: [id_dadoeco, id_itemdado])
  dadoEcologico  DadoEcologico @relation(fields: [id_dadoeco], references: [id_dadoeco])

  @@id([id_amostra, id_dadoeco, id_itemdado])
}

model AmostraMidia {
  id_amostramidia Int       @id @default(autoincrement())
  id_amostra      Int?
  tp_arquivo      String    @db.VarChar(50)
  arquivo         Bytes
  descricao       String?   @db.Text
  data_upload     DateTime  @default(now()) @db.Timestamp(6)
  amostra         Amostra?  @relation(fields: [id_amostra], references: [id_amostra])
}
